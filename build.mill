//| mill-version: 1.1.5
//| mvnDeps: ["com.lihaoyi::mill-contrib-scoverage:$MILL_VERSION"]
package build

import mill.*, scalalib.*, scalalib.publish.*
import mill.contrib.scoverage.ScoverageModule

object versions {
  val choreo          = "0.1.0"
  val scala3          = "3.8.2"
  val cats            = "2.13.0"
  val catsEffect      = "3.6.3"
  val munit           = "1.1.1"
  val munitCatsEffect = "2.1.0"
}

trait ChoreoModule extends ScalaModule {
  def scalaVersion = versions.scala3
}

object core extends ChoreoModule with PublishModule with ScoverageModule {
  def scoverageVersion = "2.1.1"
  def artifactName = "choreo"

  def publishVersion = versions.choreo

  def pomSettings = PomSettings(
    description = "Choreographic programming in Scala 3",
    organization = "me.romac",
    url = "https://github.com/romac/choreo",
    licenses = Seq(License.`BSD-3-Clause`),
    versionControl = VersionControl.github("romac", "choreo"),
    developers = Seq(
      Developer("romac", "Romain Ruetschi", "https://github.com/romac")
    )
  )

  def mvnDeps = Seq(
    mvn"org.typelevel::cats-core:${versions.cats}",
    mvn"org.typelevel::cats-free:${versions.cats}",
    mvn"org.typelevel::cats-effect:${versions.catsEffect}"
  )

  object test extends ScoverageTests with TestModule.Munit {
    def mvnDeps = Seq(
      mvn"org.scalameta::munit:${versions.munit}",
      mvn"org.typelevel::munit-cats-effect:${versions.munitCatsEffect}"
    )
  }
}

object examples extends ChoreoModule {
  def moduleDeps = Seq(core)

  def mvnDeps = Seq(
    mvn"org.typelevel::cats-core:${versions.cats}",
    mvn"org.typelevel::cats-effect:${versions.catsEffect}"
  )
}
